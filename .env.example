# SignalMind v4 — Environment Configuration
# Copy to .env and fill in your values
# Generate SECRET_KEY: python -c "import secrets; print(secrets.token_hex(32))"

# ── CRITICAL: Must be set before deployment ────────────────────────────────────
SECRET_KEY=CHANGE_ME_generate_with_python_secrets_token_hex_32

# ── Server ─────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_PATH=data/saas.db

# ── Default LLM API Keys (users can override per-account) ─────────────────────
GEMINI_API_KEY=
OPENROUTER_API_KEY=
AIML_API_KEY=

# ── Billing (Stripe) ───────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_AGENCY=price_...

# ── Admin ─────────────────────────────────────────────────────────────────────
# First user created is not auto-admin.
# Set admin via: sqlite3 data/saas.db "UPDATE users SET is_admin=1 WHERE email='your@email.com';"
# Or use the API: POST /admin/api/user/{id} with {"is_admin": true}

# ── Feature flags ──────────────────────────────────────────────────────────────
ENABLE_RATE_LIMITING=true
ENABLE_HUMAN_REVIEW=true
SCHEDULER_INTERVAL_SECONDS=60

# ── Output paths ───────────────────────────────────────────────────────────────
OUTPUT_DIR=outputs
